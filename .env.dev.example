# Copy this file to `.env.dev` and fill in values for local development.
# `.env.dev` should not be committed.

# Backend (Flask)
BACKEND_HOST=127.0.0.1
BACKEND_PORT=
# Optional override for the local SQLite database file path
# ROOM_DB_PATH=
# Optional override for the committed persistent room seed manifest
# PERSISTENT_ROOM_SEED_MANIFEST_PATH=

# Frontend (Vite)
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=
# Optional explicit frontend override. If left empty in local dev, the app falls back
# to BACKEND_HOST and BACKEND_PORT from this same file.
VITE_BACKEND_URL=

# Backend session cookie
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax

# Conda environment name to activate (see `startDevFrontAndBackend.sh`)
CONDA_ENV=
