# Copy this file to `.env.dev` and fill in values for local development.
# `.env.dev` should not be committed.

# Backend (Flask)
BACKEND_HOST=127.0.0.1
BACKEND_PORT=
# Optional override for the local SQLite database file path
# ROOM_DB_PATH=
# Optional override for the backend-owned persistent room seed manifest
# PERSISTENT_ROOM_SEED_MANIFEST_PATH=
# OpenAI API key for CrewAI coordinator, room handler, and inventory handler
OPENAI_API_KEY=
# CrewAI/OpenAI responses model used by all text agents
OPENAI_CREW_MODEL=gpt-5.1
# Image-edit model used when a room image must change visually
OPENAI_IMAGE_MODEL=gpt-image-1.5

# Frontend (Vite)
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=
# Optional explicit frontend override. If left empty in local dev, the app falls back
# to BACKEND_HOST and BACKEND_PORT from this same file.
VITE_BACKEND_URL=

# Backend session cookie
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax

# Conda environment name to activate (see `startDevFrontAndBackend.sh`)
CONDA_ENV=
