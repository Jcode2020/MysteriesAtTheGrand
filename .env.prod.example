# Copy this file to `.env.prod` and fill in values for production.
# `.env.prod` should not be committed.
#
# IMPORTANT:
# Any variable prefixed with `VITE_` is embedded in the frontend bundle
# and is publicly visible. Do not put secrets here.

# This file is a production reference template for both Railway services.
# Railway stores variables per service, so only set the variables that apply
# to the specific backend or frontend service.

# Backend service (Railway)
# Exact public frontend origin allowed to call the backend.
# Example: https://app.example.com
FRONTEND_ORIGIN=

# SQLite file on the mounted Railway volume.
ROOM_DB_PATH=

# Railway runtime/build settings
RAILPACK_PYTHON_VERSION=
BACKEND_HOST=

# Cookie security
SESSION_COOKIE_SECURE=
SESSION_COOKIE_SAMESITE=

# Railway provides PORT automatically; do not set it manually here.

# Frontend service (Vite/Railway)
# Public backend API base URL.
# Example: https://api.example.com
VITE_BACKEND_URL=
